<!DOCTYPE html>
<html lang="ne">
<head>

<meta charset="UTF-8">
<title>Raskoti BS Khabar</title>

<style>

body{
font-family:Arial;
margin:0;
background:#f5f5f5;
}

header{
background:#1e3a8a;
color:white;
padding:15px;
text-align:center;
}

nav{
background:#333;
padding:10px;
text-align:center;
}

nav a{
color:white;
margin:10px;
text-decoration:none;
font-size:18px;
}

.banner{
width:100%;
height:250px;
background:url("https://picsum.photos/1200/400") center;
background-size:cover;
}

.title{
margin:20px;
color:red;
}

.news{
display:flex;
flex-wrap:wrap;
}

.card{
background:white;
padding:15px;
margin:15px;
width:300px;
box-shadow:0 0 5px gray;
border-radius:5px;
}

footer{
background:#1e3a8a;
color:white;
text-align:center;
padding:20px;
margin-top:40px;
}

button{
padding:10px 20px;
background:red;
color:white;
border:none;
cursor:pointer;
}

</style>

</head>

<body>

<header>

<h1>Raskoti BS Khabar</h1>
<p>कालिकोट र रास्कोटका ताजा समाचार</p>

</header>

<nav>

<a href="#">होम</a>
<a href="#">राजनीति</a>
<a href="#">स्थानीय</a>
<a href="#">खेलकुद</a>
<a href="#">सम्पर्क</a>

</nav>

<div class="banner"></div>

<h2 class="title">ताजा समाचार</h2>

<div class="news" id="newsContainer"></div>

<h2 class="title">Admin Panel</h2>

<input id="title" placeholder="News Title">
<br><br>

<textarea id="content" placeholder="News Content"></textarea>
<br><br>

<button onclick="addNews()">Publish News</button>

<footer>

<p>© 2026 Raskoti BS Khabar</p>
<p>कालिकोट, कर्णाली प्रदेश</p>

</footer>

<script>

function addNews(){

let title=document.getElementById("title").value
let content=document.getElementById("content").value

let news={
title:title,
content:content
}

let allNews=JSON.parse(localStorage.getItem("news"))||[]

allNews.push(news)

localStorage.setItem("news",JSON.stringify(allNews))

showNews()

}

function showNews(){

let container=document.getElementById("newsContainer")

let allNews=JSON.parse(localStorage.getItem("news"))||[]

container.innerHTML=""

allNews.forEach(n=>{

container.innerHTML+=`

<div class="card">

<h3>${n.title}</h3>

<p>${n.content}</p>

</div>

`

})

}

showNews()

</script>

</body>
</html>
